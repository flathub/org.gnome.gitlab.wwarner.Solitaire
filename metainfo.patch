From 54dbcb25af7bd189b6abb189858481fd9ce6fc38 Mon Sep 17 00:00:00 2001
From: Will Warner <willwwarner@proton.me>
Date: Wed, 25 Mar 2026 20:44:12 -0400
Subject: [PATCH] metainfo: fix screenshot size, fix brand colors

---
 data/org.gnome.gitlab.wwarner.Solitaire.metainfo.xml.in.in | 6 +++---
 1 file changed, 3 insertions(+), 3 deletions(-)

diff --git a/data/org.gnome.gitlab.wwarner.Solitaire.metainfo.xml.in.in b/data/org.gnome.gitlab.wwarner.Solitaire.metainfo.xml.in.in
index a46a9b2..a8587db 100644
--- a/data/org.gnome.gitlab.wwarner.Solitaire.metainfo.xml.in.in
+++ b/data/org.gnome.gitlab.wwarner.Solitaire.metainfo.xml.in.in
@@ -29,7 +29,7 @@
     <control>touch</control>
   </recommends>
   <screenshots>
-    <screenshot type="default" width="850" height="850">
+    <screenshot type="default" width="700" height="700">
       <image>https://gitlab.gnome.org/wwarner/Solitaire/-/raw/main/data/screenshot-1.png</image>
       <caption>Playing a game of Klondike (solitaire)</caption>
     </screenshot>
@@ -48,8 +48,8 @@
   <content_rating type="oars-1.1" />
 
   <branding>
-    <color type="primary" scheme_preference="light">#c01c28</color>
-    <color type="primary" scheme_preference="dark">#3d3846</color>
+    <color type="primary" scheme_preference="light">#ff7373</color>
+    <color type="primary" scheme_preference="dark">#ae3b3b</color>
   </branding>
 
   <releases>
